{
  "expo": {
    "name": "Gemini Security",
    "slug": "gemini-security",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gemini.security.app"
    },
    "android": {
      "package": "com.gemini.security.app"
    },
    "plugins": [
      ["expo-router", { "origin": "https://replit.com/" }],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "eas": {
        "projectId": "8ef769b1-e1cd-492f-937f-6c1f1d439dc2"
      }
    }
  }
}
